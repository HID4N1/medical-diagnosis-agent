# FastAPI
APP_ENV=development
APP_NAME=medical-diagnosis-agent
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# MCP
MCP_SERVER_URL=http://localhost:23000/mcp

# LangSmith tracing, optional
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medical-diagnosis-agent
LANGSMITH_API_KEY=

# OpenAI, optional for future LLM-based agents
OPENAI_API_KEY=

# Academic safety label
APP_DISCLAIMER=Ce système ne remplace pas une consultation médicale.
